{
  "name": "@hrms/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "bun run --env-file ../../.env --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "type-check": "tsc --noEmit",
    "lint": "biome check .",
    "test": "bun test --env-file ../../.env",
    "seed:roles": "bun run --env-file ../../.env src/db/seed/roles.ts",
    "seed:users": "bun run --env-file ../../.env src/db/seed/users.ts",
    "seed": "bun run seed:roles && bun run seed:users",
    "db:push": "bun --env-file ../../.env x drizzle-kit push",
    "db:generate": "bun --env-file ../../.env x drizzle-kit generate",
    "db:migrate": "bun --env-file ../../.env x drizzle-kit migrate",
    "db:studio": "bun --env-file ../../.env x drizzle-kit studio"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@hrms/env": "workspace:*",
    "@hrms/shared": "workspace:*",
    "better-auth": "1.5.4",
    "drizzle-orm": "0.38.4",
    "elysia": "^1.4.27",
    "postgres": "3.4.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "bun-types": "1.2.4",
    "drizzle-kit": "0.30.4",
    "typescript": "5.7.3"
  }
}
