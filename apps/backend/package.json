{
  "name": "@hrms/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "type-check": "tsc --noEmit",
    "lint": "biome check .",
    "seed:roles": "bun run src/db/seed/roles.ts",
    "seed:users": "bun run src/db/seed/users.ts",
    "seed": "bun run seed:roles && bun run seed:users"
  },
  "dependencies": {
    "@elysiajs/cors": "1.2.0",
    "@elysiajs/swagger": "1.2.0",
    "@hrms/shared": "workspace:*",
    "better-auth": "1.2.3",
    "drizzle-orm": "0.38.4",
    "elysia": "1.2.12",
    "postgres": "3.4.5"
  },
  "devDependencies": {
    "bun-types": "1.2.4",
    "drizzle-kit": "0.30.4",
    "typescript": "5.7.3"
  }
}
