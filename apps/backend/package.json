{
  "name": "@hrms/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "bun run --env-file ../../.env --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "type-check": "tsc --noEmit",
    "lint": "biome check .",
    "test": "bun test --env-file ../../.env",
    "seed:roles": "bun run --env-file ../../.env src/db/seed/roles.ts",
    "seed:users": "bun run --env-file ../../.env src/db/seed/users.ts",
    "seed:employees": "bun run --env-file ../../.env src/db/seed/employees.ts",
    "seed:training-courses-types": "bun run --env-file ../../.env src/db/seed/training-course-types.ts",
    "seed:training-courses": "bun run --env-file ../../.env src/db/seed/training-courses.ts",
    "seed:training-registrations": "bun run --env-file ../../.env src/db/seed/training-registrations.ts",
    "seed:training-results": "bun run --env-file ../../.env src/db/seed/training-results.ts",
    "seed": "bun run seed:roles && bun run seed:users && bun run seed:employees && bun run seed:training-courses-types && bun run seed:training-courses && bun run seed:training-registrations && bun run seed:training-results",
    "db:push": "bun run --bun --env-file ../../.env drizzle-kit push",
    "db:generate": "bun run --bun --env-file ../../.env drizzle-kit generate",
    "db:migrate": "bun run --bun --env-file ../../.env drizzle-kit migrate",
    "db:studio": "bun run --bun --env-file ../../.env drizzle-kit studio"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@hrms/env": "workspace:*",
    "@hrms/shared": "workspace:*",
    "@types/pdfkit": "^0.17.5",
    "better-auth": "1.5.4",
    "drizzle-orm": "0.45.1",
    "elysia": "^1.4.27",
    "exceljs": "^4.4.0",
    "nodemailer": "^8.0.2",
    "pdfkit": "^0.17.2",
    "postgres": "3.4.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/nodemailer": "^7.0.11",
    "bun-types": "1.2.4",
    "drizzle-kit": "0.31.9",
    "typescript": "5.7.3"
  }
}
